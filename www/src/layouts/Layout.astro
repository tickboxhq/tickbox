---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Developer-first cookie consent SDK. PECR-correct script gating, Google Consent Mode v2, AI training opt-out.',
} = Astro.props
const ogTitle = title === 'Tickbox' ? title : `${title} — Tickbox`
---

<!DOCTYPE html>
<html lang="en" class="h-full bg-white text-slate-900 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{ogTitle}</title>
  </head>
  <body class="min-h-full flex flex-col">
    <header class="border-b border-slate-200">
      <div class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
        <a href="/" class="font-semibold tracking-tight text-slate-900 text-lg">Tickbox</a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/features" class="text-slate-600 hover:text-slate-900">Features</a>
          <a href="/builder" class="text-slate-600 hover:text-slate-900">Builder</a>
          <a href="/pricing" class="text-slate-600 hover:text-slate-900">Pricing</a>
          <a href="https://docs.tickbox.dev" class="text-slate-600 hover:text-slate-900">Docs</a>
          <a
            href="https://app.tickbox.dev"
            class="rounded-md bg-slate-900 px-3 py-1.5 text-white font-medium hover:bg-slate-800"
          >
            Sign in
          </a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-slate-200 mt-16">
      <div class="mx-auto max-w-6xl px-6 py-8 flex flex-wrap items-center justify-between gap-4 text-sm text-slate-500">
        <span>© Tickbox · MIT-licensed OSS · UK + EU compliance</span>
        <div class="flex items-center gap-4">
          <a href="https://docs.tickbox.dev" class="hover:text-slate-800">Docs</a>
          <a href="https://github.com/tickboxhq/tickbox" class="hover:text-slate-800">GitHub</a>
          <a href="/privacy" class="hover:text-slate-800">Privacy</a>
        </div>
      </div>
    </footer>
  </body>
</html>

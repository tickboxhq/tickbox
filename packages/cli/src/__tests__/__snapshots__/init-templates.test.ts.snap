  vendorRules: {
    // 'plausible': 'notice',
    // 'google-ads': 'consent',
  },
  defaultMode: 'consent',
  ui: {
    rejectButtonOnFirstLayer: true,
    equalProminence: true,
    honorGPC: false,
  },
}

export default defineConsent({
  jurisdiction: CUSTOM_JURISDICTION,
  policy: {
    version: '2026-05-10',

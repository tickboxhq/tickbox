// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderConfig > matches snapshot — auto + ai opt-out only 1`] = `
"import { defineConsent, jurisdictions, AI_TRAINING_CRAWLERS } from '@tickboxhq/core'

// 'auto' resolves jurisdiction by visitor country at runtime. See the multi-jurisdiction recipe:
// https://docs.tickbox.dev/recipes/multi-jurisdiction/
export default defineConsent({
  jurisdiction: 'auto',
  policy: {
    version: '2026-05-10',
  },
  categories: {
    necessary: { required: true },
    ai_training: {
      vendors: [...AI_TRAINING_CRAWLERS],
      default: false,
      description: 'AI training crawlers and LLM data collection.',
    },
  },
})
"
`;


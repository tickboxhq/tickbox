{
  "name": "@tickboxhq/cli",
  "version": "0.0.14",
  "description": "Tickbox CLI — scan a URL for tracking vendors, validate a consent config",
  "license": "MIT",
  "homepage": "https://tickbox.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tickboxhq/tickbox.git",

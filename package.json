{
  "name": "tickbox",
  "version": "0.0.0",
  "private": true,
  "description": "Developer-first cookie consent for UK websites",
  "license": "MIT",
  "homepage": "https://tickbox.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tickboxhq/tickbox.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "pnpm -r --filter='./packages/*' test",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
